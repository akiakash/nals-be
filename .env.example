SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
PORT=5050
# Optional: Postgres URI to auto-apply enrolments/flyers tables (npm run db:apply-tables)
# Supabase → Project Settings → Database → Connection string (URI). Prefer direct (port 5432) for DDL.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres
# Prefer service role key on backend when you need elevated DB access:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Optional table name used by /api/health/supabase
SUPABASE_HEALTHCHECK_TABLE=profile
